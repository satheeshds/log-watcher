query { 
  issue { 
    state { 
      type 
    }
  }
} 


###
curl \
  -X POST \
  -H "Content-Type: application/json" \
  -H "Authorization: {{$dotenv LINEAR_API_KEY}}" \
  --data '{ "query": " { projects { nodes { id name } } }" }' \
  https://api.linear.app/graphql


